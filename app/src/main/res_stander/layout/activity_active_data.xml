<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".business.role.manage.ActiveDataActivity"
    android:orientation="vertical">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/user"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/post"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/avata"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:src="@drawable/default_head"/>
            <TextView
                android:id="@+id/nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_gravity="center"
                android:textSize="56sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/userID"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:id="@+id/createTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textSize="14sp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/post"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            app:cardDescription="@string/article_number"/>

        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/follow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/fans"
            app:layout_constraintTop_toBottomOf="@+id/post"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            app:cardDescription="@string/follow_person"/>
        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/fans"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/follow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/post"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            app:cardDescription="@string/fans"/>

        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/support"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/against"
            app:layout_constraintTop_toBottomOf="@+id/follow"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            app:cardDescription="@string/get_support"/>
        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/against"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/support"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fans"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            app:cardDescription="@string/against_gain"/>

        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/inform"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/reported"
            app:layout_constraintTop_toBottomOf="@+id/support"
            app:layout_constraintBottom_toBottomOf="parent"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardDescription="@string/number_user_report"/>
        <com.jayce.vexis.foundation.ui.block.BasicInformationCard
            android:id="@+id/reported"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/inform"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/against"
            app:layout_constraintBottom_toBottomOf="parent"
            app:cardElevation="8dp"
            app:cardCornerRadius="12dp"
            app:contentPadding="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardDescription="@string/reported_num"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/delete_user"/>
        <Button
            android:id="@+id/setAdministrator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/set_to_admin"/>
    </LinearLayout>
</LinearLayout>