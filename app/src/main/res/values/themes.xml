<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Secret" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/vermilion</item>
        <item name="colorSecondary">@color/indigo</item>
        <item name="android:textColorPrimary">@color/inkyBlack</item>
        <item name="android:textColorSecondary">@color/taupe</item>
        <item name="android:windowBackground">@color/paleGray</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/inkyBlack</item>
        <item name="colorPrimaryContainer">?attr/colorPrimary</item>

        <item name="preferenceTheme">@style/customPreference</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialButtonStyle">@style/buttonStyle</item>
        <item name="android:typeface">monospace</item>
    </style>
    
    <style name="buttonStyle" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/ChestnutBrown</item>
        <item name="textAllCaps">false</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="customPreference" parent="@style/PreferenceThemeOverlay">
        <item name="preferenceStyle">@style/preferenceBase</item>
        <item name="preferenceCategoryStyle">@style/preferenceCate</item>
        <item name="checkBoxPreferenceStyle">@style/checkPre</item>
        <item name="editTextPreferenceStyle">@style/editPreference</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
    </style>

    <style name="editPreference" parent="Preference.DialogPreference.EditTextPreference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="icon">@null</item>
    </style>

    <style name="checkPre" parent="Preference.CheckBoxPreference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="icon">@null</item>
    </style>

    <style name="preferenceCate" parent="Preference.Category.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="icon">@null</item>
    </style>

    <style name="preferenceBase" parent="Preference">
        <item name="iconSpaceReserved">false</item>
        <item name="icon">@null</item>
    </style>

    <style name="Dialog" parent="Theme.Material3.Light.Dialog">
        <!--背景颜色及和透明程度-->
        <item name="android:windowBackground">#F5F5F5</item>
        <!--是否去除标题 -->
        <item name="android:windowNoTitle">true</item>
        <!--是否去除边框-->
        <item name="android:windowFrame">@null</item>
        <!--是否浮现在activity之上-->
        <item name="android:windowIsFloating">true</item>
        <!--是否模糊-->
        <item name="android:backgroundDimEnabled">false</item>
        <!--设置对话框居中-->
        <item name="android:layout_gravity">center</item>
        <item name="android:buttonStyle">@style/buttonStyle</item>
    </style>

</resources>