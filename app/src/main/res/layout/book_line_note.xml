<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".business.kit.book.note.LineNoteActivity">
    <TextView
        android:id="@+id/bookTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/bookTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bookTitle"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bookBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:barrierDirection="end"
        app:constraint_referenced_ids="bookTextViewRecord, stageWrapper, bookSumTextview"/>
    <TextView
        android:id="@+id/bookTextViewRecord"
        android:layout_width="48dp"
        android:layout_height="24dp"
        android:text="@string/record"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:background="#42EC4D"
        app:layout_constraintEnd_toEndOf="@id/bookBarrier"
        app:layout_constraintTop_toBottomOf="@id/bookTime"
        app:layout_constraintStart_toStartOf="parent"/>
    <HorizontalScrollView
        android:id="@+id/playerWrapper"
        android:layout_width="@dimen/none"
        android:layout_height="@dimen/none"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/bookTime"
        app:layout_constraintStart_toStartOf="@id/bookBarrier"
        app:layout_constraintBottom_toBottomOf="@id/bookTextViewRecord"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#E3F2FD">
        <LinearLayout
            android:id="@+id/playerName"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="start"/>
    </HorizontalScrollView>
    <ScrollView
        android:id="@+id/stageWrapper"
        android:layout_width="@dimen/none"
        android:layout_height="@dimen/none"
        android:scrollbars="none"
        android:background="#EDE7F6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bookBarrier"
        app:layout_constraintTop_toBottomOf="@id/bookTextViewRecord"
        app:layout_constraintBottom_toTopOf="@id/bookSumTextview">
        <LinearLayout
            android:id="@+id/stage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>
    <HorizontalScrollView
        android:id="@+id/bookDataWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@id/bookTextViewRecord"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bookTextViewRecord"
        app:layout_constraintBottom_toTopOf="@id/bookSumTextview">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lineRv"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>
    </HorizontalScrollView>
    <TextView
        android:id="@+id/bookSumTextview"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:text="@string/total"
        android:gravity="center"
        android:background="#A5D6A7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/bookBarrier"
        app:layout_constraintBottom_toTopOf="@id/bookMenu"/>
    <HorizontalScrollView
        android:id="@+id/sumWrapper"
        android:layout_width="@dimen/none"
        android:layout_height="@dimen/none"
        android:layout_weight="1"
        android:background="#A8DAF4"
        app:layout_constraintStart_toEndOf="@id/bookBarrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bookMenu"
        app:layout_constraintTop_toTopOf="@id/bookSumTextview">
        <LinearLayout
            android:id="@+id/bookSum"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"/>
    </HorizontalScrollView>
    <LinearLayout
        android:id="@+id/bookMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#F5F5F5"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView
            android:id="@+id/addUser"
            android:layout_width="@dimen/none"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/add"
            android:importantForAccessibility="no"/>
        <ImageView
            android:id="@+id/addRecord"
            android:layout_width="@dimen/none"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/payment"
            android:importantForAccessibility="no"/>
        <ImageView
            android:id="@+id/save"
            android:layout_width="@dimen/none"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/save"
            android:importantForAccessibility="no"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>